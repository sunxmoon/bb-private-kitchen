# === Database ===
# Local SQLite (dev):
# DATABASE_URL=sqlite:///./dev.db
# Docker PostgreSQL (production):
DATABASE_URL=postgresql://moon:change_me@db:5432/ordering_db

# === Docker Compose (overrides .env variables) ===
DB_USER=moon
DB_PASSWORD=change_me
DB_NAME=ordering_db
PORT=8002

# === CSRF Secret (optional, auto-generated if empty) ===
# CSRF_SECRET=your-random-secret-here

# === Gemini AI ===
# Docker: bridge to host gemini CLI (auto-set in docker-compose)
# GEMINI_HOST_URL=http://host.docker.internal:8765
# Local: omit to call gemini CLI directly from PATH
