# === Database ===
DATABASE_URL=postgresql://moon:change_me@db:5432/ordering_db

# === Docker Compose ===
DB_USER=moon
DB_PASSWORD=change_me
DB_NAME=ordering_db
PORT=8002

# === Security ===
# ENV=production  # Uncomment to enable Secure Cookie
# CSRF_SECRET=your-random-secret-here
# COOKIE_SECRET=your-random-secret-here

# === Gemini AI ===
# Docker: bridge to host gemini CLI
GEMINI_HOST_URL=http://host.docker.internal:8765
# Local: omit GEMINI_HOST_URL to call gemini CLI directly from PATH
